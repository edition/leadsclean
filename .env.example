# LLM provider keys — at least one required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DASHSCOPE_API_KEY=sk-...         # Alibaba Qwen
MINIMAX_API_KEY=...

# SQLite database file path (default: ./leadsclean.db in the working directory)
# On Railway/Render, point this to a persistent volume:
# LEADSCLEAN_DB=/data/leadsclean.db

# Demo mode — returns a fixture response without calling any LLM or checking API keys.
# Set to 1 for local testing or public demos. Leave unset in production.
# LEADSCLEAN_DEMO=1
